<?xml version="1.0" encoding="utf-8"?>
<!--
  Two-panel layout optimised for:
  · Android TV  — 1080p, D-pad focus, 10-foot UI (48sp+ text, 10% safe-area margins)
  · Android Car — AAOS touch, large targets (56dp+ minimum), no small text
  · Phone/Tablet — normal touch, smaller sidebar collapses
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg">

    <!-- ── LEFT SIDEBAR ──────────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/sidebar"
        android:layout_width="220dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:background="@color/surface_nav"
        android:paddingTop="16dp"
        android:paddingBottom="12dp"
        android:elevation="6dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/now_playing_bar">

        <!-- App logo row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:paddingBottom="4dp">
            <ImageView
                android:layout_width="32dp" android:layout_height="32dp"
                android:src="@drawable/ic_music_note_large"
                android:layout_marginEnd="12dp"/>
            <TextView
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="WebDAV Music"
                android:textSize="16sp" android:textStyle="bold"
                android:textColor="@color/on_surface" android:singleLine="true"/>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/divider" android:layout_marginBottom="8dp"/>

        <!-- Nav buttons — TV: 60dp tall for easy D-pad focus -->
        <include layout="@layout/nav_button" android:id="@+id/nav_all"
            android:layout_width="match_parent" android:layout_height="60dp"/>
        <include layout="@layout/nav_button" android:id="@+id/nav_local"
            android:layout_width="match_parent" android:layout_height="60dp"/>
        <include layout="@layout/nav_button" android:id="@+id/nav_albums"
            android:layout_width="match_parent" android:layout_height="60dp"/>
        <include layout="@layout/nav_button" android:id="@+id/nav_artists"
            android:layout_width="match_parent" android:layout_height="60dp"/>
        <include layout="@layout/nav_button" android:id="@+id/nav_favorites"
            android:layout_width="match_parent" android:layout_height="60dp"/>
        <include layout="@layout/nav_button" android:id="@+id/nav_playlists"
            android:layout_width="match_parent" android:layout_height="60dp"/>

        <Space android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"/>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/divider" android:layout_marginBottom="8dp"/>

        <include layout="@layout/nav_button" android:id="@+id/nav_settings"
            android:layout_width="match_parent" android:layout_height="60dp"/>

        <!-- Empty state CTA -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_add_account"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:layout_marginHorizontal="12dp" android:layout_marginTop="6dp"
            android:text="+ 添加账户" android:textSize="14sp"
            android:visibility="gone" android:focusable="true"
            style="@style/Widget.Material3.Button"/>
    </LinearLayout>

    <!-- ── RIGHT CONTENT ─────────────────────────────────────────────── -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/content_area"
        android:layout_width="0dp" android:layout_height="0dp"
        app:layout_constraintStart_toEndOf="@id/sidebar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/now_playing_bar">

        <!-- Top bar -->
        <LinearLayout
            android:id="@+id/top_bar"
            android:layout_width="0dp" android:layout_height="64dp"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:paddingHorizontal="20dp" android:background="@color/surface"
            android:elevation="2dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/tv_section_title"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="所有歌曲" android:textSize="20sp" android:textStyle="bold"
                android:textColor="@color/on_surface"/>

            <androidx.appcompat.widget.SearchView
                android:id="@+id/search_view"
                android:layout_width="280dp" android:layout_height="44dp"
                android:focusable="true"/>
        </LinearLayout>

        <!-- Scan status bar -->
        <LinearLayout
            android:id="@+id/scan_status_bar"
            android:layout_width="0dp" android:layout_height="44dp"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:paddingHorizontal="20dp" android:background="@color/primary_container"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/top_bar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">
            <ProgressBar android:layout_width="22dp" android:layout_height="22dp"
                android:layout_marginEnd="12dp" style="@style/Widget.AppCompat.ProgressBar"/>
            <TextView android:id="@+id/tv_scan_status"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:textSize="13sp"
                android:textColor="@color/on_primary_container"
                android:singleLine="true" android:ellipsize="end"/>
        </LinearLayout>

        <!-- Song list -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_view"
            android:layout_width="0dp" android:layout_height="0dp"
            android:clipToPadding="false" android:paddingBottom="8dp"
            android:descendantFocusability="afterDescendants"
            app:layout_constraintTop_toBottomOf="@id/scan_status_bar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <!-- Empty views -->
        <TextView
            android:id="@+id/tv_empty"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="18sp" android:textColor="@color/on_bg_secondary"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/top_bar"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <LinearLayout
            android:id="@+id/tv_empty_hint"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:orientation="vertical" android:gravity="center"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/top_bar"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🎵" android:textSize="64sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="点击左侧「账户与设置」添加 WebDAV 账户或扫描本地音乐"
                android:textSize="15sp" android:textColor="@color/on_bg_secondary"
                android:gravity="center" android:layout_marginTop="12dp"/>
        </LinearLayout>

        <!-- FAB: scan -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fab_scan"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_margin="20dp"
            android:src="@drawable/ic_refresh"
            android:contentDescription="扫描" android:focusable="true"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ── NOW PLAYING BAR ───────────────────────────────────────────── -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/now_playing_bar"
        android:layout_width="0dp" android:layout_height="80dp"
        android:background="@color/now_playing_bg"
        android:elevation="10dp" android:visibility="gone"
        android:focusable="true" android:clickable="true"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageView
            android:id="@+id/bar_album_art"
            android:layout_width="64dp" android:layout_height="64dp"
            android:layout_margin="8dp" android:scaleType="centerCrop"
            android:src="@drawable/ic_music_note_large"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <LinearLayout
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:orientation="vertical" android:layout_marginStart="8dp"
            app:layout_constraintStart_toEndOf="@id/bar_album_art"
            app:layout_constraintEnd_toStartOf="@id/bar_controls"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">
            <TextView android:id="@+id/tv_bar_title"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textSize="15sp" android:textStyle="bold"
                android:maxLines="1" android:ellipsize="marquee"
                android:marqueeRepeatLimit="marquee_forever" android:selected="true"
                android:textColor="@color/on_now_playing"/>
            <TextView android:id="@+id/tv_bar_artist"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textSize="13sp" android:maxLines="1" android:ellipsize="end"
                android:textColor="@color/on_now_playing_secondary"/>
        </LinearLayout>

        <ProgressBar android:id="@+id/bar_progress"
            android:layout_width="24dp" android:layout_height="24dp"
            android:visibility="gone"
            app:layout_constraintEnd_toStartOf="@id/bar_controls"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <!-- Large controls: prev / play-pause / next — all 56dp+ for car/TV -->
        <LinearLayout
            android:id="@+id/bar_controls"
            android:layout_width="wrap_content" android:layout_height="match_parent"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:paddingEnd="12dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageButton android:id="@+id/btn_bar_prev"
                android:layout_width="56dp" android:layout_height="56dp"
                android:src="@drawable/ic_skip_previous"
                android:background="@drawable/bg_icon_btn"
                android:padding="12dp" android:focusable="true"
                android:contentDescription="上一首"/>

            <ImageButton android:id="@+id/btn_bar_play_pause"
                android:layout_width="64dp" android:layout_height="64dp"
                android:src="@drawable/ic_play"
                android:background="@drawable/bg_play_btn_circle"
                android:padding="16dp" android:layout_marginHorizontal="8dp"
                android:focusable="true" android:contentDescription="播放/暂停"/>

            <ImageButton android:id="@+id/btn_bar_next"
                android:layout_width="56dp" android:layout_height="56dp"
                android:src="@drawable/ic_skip_next"
                android:background="@drawable/bg_icon_btn"
                android:padding="12dp" android:focusable="true"
                android:contentDescription="下一首"/>
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
