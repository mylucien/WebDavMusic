<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center" android:paddingHorizontal="16dp" android:paddingVertical="8dp">
    <TextView android:id="@+id/tv_lyric_main"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:gravity="center" android:textSize="16sp"
        android:textColor="@color/on_bg_secondary" android:lineSpacingMultiplier="1.3"/>
    <TextView android:id="@+id/tv_lyric_translated"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:gravity="center" android:textSize="12sp"
        android:textColor="@color/on_bg_tertiary" android:visibility="gone"
        android:layout_marginTop="2dp"/>
</LinearLayout>
