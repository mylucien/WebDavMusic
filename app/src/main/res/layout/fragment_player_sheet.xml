<?xml version="1.0" encoding="utf-8"?>
<!-- Full-screen player: left=album art, center=metadata+controls, right=lyrics -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg">

    <!-- Close -->
    <ImageButton android:id="@+id/btn_close"
        android:layout_width="52dp" android:layout_height="52dp"
        android:src="@drawable/ic_keyboard_arrow_down"
        android:background="@drawable/bg_icon_btn"
        android:padding="12dp" android:focusable="true"
        android:contentDescription="关闭"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_margin="12dp"/>

    <!-- LEFT: Album Art -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/album_art_card"
        android:layout_width="0dp" android:layout_height="0dp"
        app:cardCornerRadius="20dp" app:cardElevation="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/right_panel"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintHorizontal_bias="0"
        app:layout_constraintWidth_percent="0.35"
        android:layout_margin="28dp">
        <ImageView android:id="@+id/iv_album_art"
            android:layout_width="match_parent" android:layout_height="match_parent"
            android:scaleType="centerCrop" android:src="@drawable/ic_music_note_large"/>
    </com.google.android.material.card.MaterialCardView>

    <!-- CENTER/RIGHT PANEL -->
    <LinearLayout
        android:id="@+id/right_panel"
        android:layout_width="0dp" android:layout_height="0dp"
        android:orientation="vertical"
        android:paddingEnd="24dp" android:paddingTop="20dp" android:paddingBottom="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/album_art_card"
        app:layout_constraintEnd_toStartOf="@id/lyrics_panel">

        <!-- Buffering spinner -->
        <ProgressBar android:id="@+id/loading_spinner"
            android:layout_width="28dp" android:layout_height="28dp"
            android:visibility="gone" android:layout_marginBottom="8dp"/>

        <!-- Title -->
        <TextView android:id="@+id/tv_title"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textSize="24sp" android:textStyle="bold"
            android:maxLines="2" android:ellipsize="end"
            android:textColor="@color/on_surface"/>

        <!-- Artist -->
        <TextView android:id="@+id/tv_artist"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textSize="17sp" android:maxLines="1" android:ellipsize="end"
            android:textColor="@color/primary" android:layout_marginTop="4dp"/>

        <!-- Album -->
        <TextView android:id="@+id/tv_album"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textSize="13sp" android:maxLines="1" android:ellipsize="end"
            android:textColor="@color/on_bg_secondary"
            android:layout_marginTop="2dp" android:layout_marginBottom="20dp"/>

        <!-- Seek bar -->
        <SeekBar android:id="@+id/seek_bar"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:max="1000" android:focusable="true"
            android:thumbTint="@color/primary" android:progressTint="@color/primary"/>

        <!-- Time labels -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp" android:layout_marginBottom="16dp">
            <TextView android:id="@+id/tv_current_time"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="0:00"
                android:textSize="13sp" android:textColor="@color/on_bg_secondary"/>
            <TextView android:id="@+id/tv_total_time"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="0:00" android:textSize="13sp" android:textColor="@color/on_bg_secondary"/>
        </LinearLayout>

        <!-- Main controls — 72dp play button for TV/car -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center"
            android:layout_marginBottom="12dp">

            <ImageButton android:id="@+id/btn_shuffle"
                android:layout_width="52dp" android:layout_height="52dp"
                android:src="@drawable/ic_shuffle" android:background="@drawable/bg_icon_btn"
                android:padding="13dp" android:focusable="true" android:alpha="0.38"
                android:contentDescription="随机播放"/>

            <ImageButton android:id="@+id/btn_prev"
                android:layout_width="64dp" android:layout_height="64dp"
                android:src="@drawable/ic_skip_previous" android:background="@drawable/bg_icon_btn"
                android:padding="14dp" android:focusable="true"
                android:layout_marginHorizontal="4dp" android:contentDescription="上一首"/>

            <ImageButton android:id="@+id/btn_play_pause"
                android:layout_width="80dp" android:layout_height="80dp"
                android:src="@drawable/ic_play" android:background="@drawable/bg_play_btn_circle"
                android:padding="20dp" android:focusable="true"
                android:layout_marginHorizontal="4dp" android:contentDescription="播放/暂停"/>

            <ImageButton android:id="@+id/btn_next"
                android:layout_width="64dp" android:layout_height="64dp"
                android:src="@drawable/ic_skip_next" android:background="@drawable/bg_icon_btn"
                android:padding="14dp" android:focusable="true"
                android:layout_marginHorizontal="4dp" android:contentDescription="下一首"/>

            <ImageButton android:id="@+id/btn_repeat"
                android:layout_width="52dp" android:layout_height="52dp"
                android:src="@drawable/ic_repeat" android:background="@drawable/bg_icon_btn"
                android:padding="13dp" android:focusable="true" android:alpha="0.38"
                android:contentDescription="循环"/>
        </LinearLayout>

        <!-- Secondary: favorite -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center">
            <ImageButton android:id="@+id/btn_favorite"
                android:layout_width="52dp" android:layout_height="52dp"
                android:src="@drawable/ic_favorite_border" android:background="@drawable/bg_icon_btn"
                android:padding="12dp" android:focusable="true" android:contentDescription="收藏"/>

            <!-- Toggle lyrics panel -->
            <ImageButton android:id="@+id/btn_toggle_lyrics"
                android:layout_width="52dp" android:layout_height="52dp"
                android:src="@drawable/ic_lyrics"
                android:background="@drawable/bg_icon_btn"
                android:padding="12dp" android:focusable="true"
                android:layout_marginStart="8dp" android:contentDescription="歌词"/>
        </LinearLayout>
    </LinearLayout>

    <!-- RIGHT: Lyrics panel -->
    <FrameLayout
        android:id="@+id/lyrics_panel"
        android:layout_width="260dp"
        android:layout_height="0dp"
        android:background="@color/lyrics_bg"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.webdavmusic.ui.lyrics.LyricsView
            android:id="@+id/lyrics_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
