<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="vertical" android:padding="16dp" android:background="@color/surface">

    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="WebDAV 账户" android:textSize="22sp" android:textStyle="bold"
        android:textColor="@color/on_surface" android:layout_marginBottom="12dp"/>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginBottom="12dp">
        <com.google.android.material.button.MaterialButton android:id="@+id/btn_add_account"
            android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
            android:text="+ 添加账户" android:layout_marginEnd="8dp"
            style="@style/Widget.Material3.Button" android:focusable="true"/>
        <com.google.android.material.button.MaterialButton android:id="@+id/btn_scan_all"
            android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
            android:text="🔍 扫描全部" android:layout_marginEnd="8dp"
            style="@style/Widget.Material3.Button.OutlinedButton" android:focusable="true"/>
        <com.google.android.material.button.MaterialButton android:id="@+id/btn_scan_local"
            android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
            android:text="📱 扫描本地" style="@style/Widget.Material3.Button.OutlinedButton"
            android:focusable="true"/>
    </LinearLayout>

    <TextView android:id="@+id/tv_no_accounts"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="还没有账户，点击「添加账户」开始使用"
        android:textSize="14sp" android:textColor="@color/on_bg_secondary"
        android:gravity="center" android:padding="20dp" android:visibility="gone"/>

    <androidx.recyclerview.widget.RecyclerView android:id="@+id/rv_accounts"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:nestedScrollingEnabled="false"/>
</LinearLayout>
