<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- TV D-pad focused: solid purple fill = unmissable highlight -->
    <item android:state_focused="true" android:state_pressed="false">
        <layer-list>
            <item><shape><solid android:color="#FF6750A4"/><corners android:radius="0dp"/></shape></item>
            <item android:left="4dp">
                <shape><solid android:color="#00000000"/></shape>
            </item>
        </layer-list>
    </item>
    <!-- Active tab selected -->
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="#2A6750A4"/>
            <stroke android:width="3dp" android:color="#FF6750A4"/>
        </shape>
    </item>
    <!-- Pressed -->
    <item android:state_pressed="true">
        <shape><solid android:color="#406750A4"/></shape>
    </item>
    <!-- Default -->
    <item><shape><solid android:color="#00000000"/></shape></item>
</selector>